# MLBB-TournamentBot — .env template
# Copy to .env and fill in the values. Never commit .env to git.

# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=
# Application client ID (numeric)
DISCORD_CLIENT_ID=
# Comma-separated list of guild (server) IDs where the bot operates
GUILD_IDS=
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Roles (Discord role names, not IDs) ─────────────────────────────────────
# Organizers can manage tournaments
ORGANIZER_ROLES=Tournament Organizer,DEV
# Admins have full override (dispute resolution, force actions)
ADMIN_ROLES=admins,DEV

# ─── WordPress / SportsPress (play.mlbb.site) ────────────────────────────────
WP_PLAY_MLBB_URL=https://play.mlbb.site
WP_PLAY_MLBB_USER=admin
# WP Application Password (not the login password)
WP_PLAY_MLBB=

# ─── Database (shared with WordPress) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=playmlbb_db
DB_USER=wpdbuser
DB_PASSWORD=

# ─── Claude API (for screenshot parsing) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Discord channel/category IDs ────────────────────────────────────────────
# MATCH_VOICE_CATEGORY_ID is REQUIRED — the bot bootstraps 4 text channels inside it.
# Get it from Discord: enable Developer Mode, right-click category, "Copy ID"
MATCH_VOICE_CATEGORY_ID=

# These 4 are auto-populated by the bot on first startup — leave blank on fresh install
MATCH_NOTIFICATIONS_CHANNEL_ID=
ADMIN_LOG_CHANNEL_ID=
BOT_COMMANDS_CHANNEL_ID=
BOT_LEAGUE_CHANNEL_ID=

# ─── Match play window (Thu-Sun, 7-11 PM local) ──────────────────────────────
MATCH_WINDOW_START_HOUR=19
MATCH_WINDOW_END_HOUR=23
MATCH_WINDOW_TZ=America/Los_Angeles

# ─── Pick-up tournament (48-hour deadline per round) ─────────────────────────
PICKUP_ROUND_HOURS=48
